# 本地直接运行 node（非 Docker）时可复制为 server/.env
PORT=3000
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=blog
MYSQL_PASSWORD=blogpass_change_me
MYSQL_DATABASE=blog
JWT_SECRET=dev_change_me
# 生产部署：NODE_ENV=production + 强 JWT_SECRET（勿用 dev_change_me）
# NODE_ENV=production
# CORS_ORIGIN=https://你的站点
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
BLOG_TITLE=写作笔记
BLOG_DESCRIPTION=本地开发
# 顶栏「上午/下午/晚上好，某某」中的显示名
SITE_OWNER_NAME=
