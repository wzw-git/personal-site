# 复制为 .env 后由 docker compose 读取
HTTP_PORT=8090
MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_PASSWORD=blogpass_change_me
# 至少 32 字节随机串；切勿使用示例值上线。生产环境设置 NODE_ENV=production 时 API 会拒绝弱密钥
JWT_SECRET=change_me_to_random_long_string
# 可选：限制浏览器跨域访问 API 的来源（逗号分隔完整源，如 https://blog.example.com）
# CORS_ORIGIN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
BLOG_TITLE=写作笔记
BLOG_DESCRIPTION=我的博客
SITE_OWNER_NAME=

# 首页天气（聚合数据 http://apis.juhe.cn/simpleWeather/query ）
# 在个人中心查看 key；勿提交含真实 key 的 .env
JUHE_WEATHER_KEY=
JUHE_WEATHER_CITY=深圳
# 上游每日最多请求次数（与套餐一致，默认 50）
JUHE_WEATHER_DAILY_LIMIT=50
# 命中缓存则不请求上游；默认 28800000=8 小时
WEATHER_CACHE_TTL_MS=28800000
